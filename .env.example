# required secrets
POSTGRES_PASSWORD=change_me_in_production
REDIS_PASSWORD=change_me_in_production
PRAMAGENT_API_KEY=change_me_in_production
PRAMAGENT_SIGNING_KEY=change_me_in_production
PRAMAGENT_JWT_SECRET=change_me_in_production
PRAMAGENT_DASHBOARD_KEY=change_me_in_production

# optional local ports and runtime settings
COMPOSE_PROJECT_NAME=pramagent
POSTGRES_USER=pramagent
POSTGRES_DB=pramagent
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8080
DASHBOARD_PORT=8501
PRAMAGENT_DASHBOARD_TENANT=default
PRAMAGENT_DASHBOARD_ALLOW_SUPER_ADMIN=false
PRAMAGENT_DASHBOARD_SECURE_COOKIE=false
PRAMAGENT_DASHBOARD_REDIS_URL=
PRAMAGENT_LOG_LEVEL=info
PRAMAGENT_MAX_INPUT_BYTES=65536
PRAMAGENT_RATE_LIMIT_CAPACITY=100
PRAMAGENT_RATE_LIMIT_REFILL=10
PRAMAGENT_QUOTA_CALLS=
PRAMAGENT_QUOTA_TOOL_VALIDATIONS=
PRAMAGENT_QUOTA_COST_USD=
PRAMAGENT_QUOTA_WINDOW_S=86400

# usage analytics / billing hook (optional, fail-open)
PRAMAGENT_BILLING_WEBHOOK_URL=
PRAMAGENT_BILLING_WEBHOOK_SECRET=
PRAMAGENT_BILLING_WEBHOOK_TIMEOUT_S=2.0

# HITL Slack integration (optional)
PRAMAGENT_HITL_SLACK_TOKEN=
PRAMAGENT_HITL_SLACK_CHANNEL=

# OpenTelemetry (optional)
PRAMAGENT_OTEL_ENDPOINT=
