# ── required secrets ─────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_in_production
REDIS_PASSWORD=change_me_in_production
VT_API_KEY=change_me_in_production
VT_SIGNING_KEY=change_me_in_production

# ── optional ─────────────────────────────────────────────────────────────────
POSTGRES_USER=veritrace
POSTGRES_DB=veritrace
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8080
DASHBOARD_PORT=8501
VT_LOG_LEVEL=info
VT_MAX_INPUT_BYTES=65536
VT_RATE_LIMIT_CAPACITY=100
VT_RATE_LIMIT_REFILL=10

# ── HITL Slack integration (optional) ────────────────────────────────────────
VT_HITL_SLACK_TOKEN=
VT_HITL_SLACK_CHANNEL=

# ── OpenTelemetry (optional) ──────────────────────────────────────────────────
VT_OTEL_ENDPOINT=
