# Veritrace API auth
# Format: tenant:key,tenant2:key2
VERITRACE_API_KEYS=bank:vt_change_me,hospital:vt_change_me_too
VERITRACE_JWT_SECRET=change_me_to_a_long_random_secret

# Persistence
# VERITRACE_DB=veritrace.db

# Provider selection: mock, openai, gemini, anthropic, ollama, local
VERITRACE_PROVIDER=mock

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama
# OLLAMA_MODEL=llama3.2:1b
# OLLAMA_HOST=http://localhost:11434

# OpenAI-compatible local/self-hosted server
# LOCAL_LLM_BASE_URL=http://localhost:8001/v1
# LOCAL_MODEL=local-model-name
# LOCAL_LLM_API_KEY=

# Slack HITL approvals
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_CHANNEL_ID=C...
# VERITRACE_PUBLIC_URL=https://your-public-url.example
VERITRACE_HITL_TIMEOUT_S=300

# Rate limiting
VERITRACE_RATE_BURST=60
VERITRACE_RATE_PER_SEC=1.0
