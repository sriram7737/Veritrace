# ─────────────────────────────────────────────────────────────────────────────
# Pramagent environment template
#
# Required values are intentionally EMPTY: docker-compose uses ${VAR:?...}
# interpolation, so an unfilled secret fails the deploy loudly instead of
# booting with a published placeholder. Both services additionally refuse to
# start if a secret matches any known placeholder spelling or is < 16 chars.
#
# Generate each secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ─────────────────────────────────────────────────────────────────────────────

# ── required secrets ─────────────────────────────────────────────────────────
# (required, string) Postgres superuser password for the compose stack
POSTGRES_PASSWORD=
# (required, string) Redis requirepass for the compose stack
REDIS_PASSWORD=
# (required, string) API bearer key mapped to the "default" tenant
PRAMAGENT_API_KEY=
# (required, string) audit signing key
PRAMAGENT_SIGNING_KEY=
# (required, string, >=16 chars) HS256 secret for tenant JWTs + dashboard sessions
PRAMAGENT_JWT_SECRET=
# (required, string) shared key for dashboard X-API-Key / fallback login
PRAMAGENT_DASHBOARD_KEY=

# ── persistent store (required: choose exactly one) ──────────────────────────
# The API refuses to start unless one of these three is set (P0-1).
# (option 1, string DSN) compose builds this from POSTGRES_* automatically
#PRAMAGENT_POSTGRES_DSN=postgresql://pramagent:<password>@postgres:5432/pramagent
# (option 2, string path) single-node SQLite persistence
#PRAMAGENT_DB=/data/pramagent.db
# (option 3, dev only) volatile in-memory store, lost on restart
#PRAMAGENT_ALLOW_MEMORY_STORE=1

# ── LLM provider (optional, default: mock) ───────────────────────────────────
# (optional, enum: mock|anthropic|openai|openai-compatible|gemini|ollama)
PRAMAGENT_PROVIDER=mock
# (optional, string) required when PRAMAGENT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# (optional, string) required when PRAMAGENT_PROVIDER=openai
OPENAI_API_KEY=
# (optional, string) required when PRAMAGENT_PROVIDER=gemini
GEMINI_API_KEY=
# (optional, string, default http://localhost:11434) Ollama daemon URL
OLLAMA_HOST=

# ── API service (optional) ───────────────────────────────────────────────────
# (optional, csv of origins, default empty = no CORS) e.g. https://app.example.com
PRAMAGENT_CORS_ORIGINS=
# (optional, url) public base URL of this API — required for Slack HITL callbacks
PRAMAGENT_PUBLIC_URL=
# (optional, string, default info) log level
PRAMAGENT_LOG_LEVEL=info
# (optional, int bytes, default 65536) input size cap enforced by IsolationLayer
PRAMAGENT_MAX_INPUT_BYTES=65536
# (optional, int, default 100) rate-limit burst capacity per tenant/IP
PRAMAGENT_RATE_LIMIT_CAPACITY=100
# (optional, float tokens/s, default 10) rate-limit refill
PRAMAGENT_RATE_LIMIT_REFILL=10

# ── per-tenant usage quotas (optional, empty = unlimited) ────────────────────
# (optional, int) max calls per window
PRAMAGENT_QUOTA_CALLS=
# (optional, int) max tool validations per window
PRAMAGENT_QUOTA_TOOL_VALIDATIONS=
# (optional, float USD) max provider spend per window
PRAMAGENT_QUOTA_COST_USD=
# (optional, int seconds, default 86400) quota window
PRAMAGENT_QUOTA_WINDOW_S=86400

# ── usage analytics / billing hook (optional, fail-open) ─────────────────────
# (optional, https url) billing webhook sink
PRAMAGENT_BILLING_WEBHOOK_URL=
# (optional, string) shared-secret header for the billing webhook
PRAMAGENT_BILLING_WEBHOOK_SECRET=
# (optional, float seconds, default 2.0) billing webhook timeout
PRAMAGENT_BILLING_WEBHOOK_TIMEOUT_S=2.0

# ── HITL Slack integration (optional; all four required to enable) ───────────
# (optional, string) Slack bot token (xoxb-…)
SLACK_BOT_TOKEN=
# (optional, string) Slack channel for approval messages
SLACK_CHANNEL_ID=
# (optional, string) Slack signing secret for callback verification
SLACK_SIGNING_SECRET=
# legacy aliases still honored by compose
PRAMAGENT_HITL_SLACK_TOKEN=
PRAMAGENT_HITL_SLACK_CHANNEL=

# ── encryption at rest (optional) ────────────────────────────────────────────
# (optional, Fernet key) enables EncryptedSQLiteStore; generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PRAMAGENT_ENCRYPTION_KEY=
# (optional, Fernet key) S3 cold-archive encryption key
PRAMAGENT_ARCHIVE_KEY=

# ── OpenTelemetry (optional) ─────────────────────────────────────────────────
# (optional, OTLP gRPC endpoint) e.g. http://otel-collector:4317
PRAMAGENT_OTEL_ENDPOINT=

# ── dashboard (optional) ─────────────────────────────────────────────────────
# (optional, string, default default) tenant scope for dashboard sessions
PRAMAGENT_DASHBOARD_TENANT=default
# (optional, bool, default false) required before tenant "*" is honored
PRAMAGENT_DASHBOARD_ALLOW_SUPER_ADMIN=false
# (optional, bool, default false) set true behind TLS
PRAMAGENT_DASHBOARD_SECURE_COOKIE=false
# (optional, redis url) dashboard rate-limit/session-revocation backend
PRAMAGENT_DASHBOARD_REDIS_URL=

# ── local ports / compose project (optional) ─────────────────────────────────
COMPOSE_PROJECT_NAME=pramagent
POSTGRES_USER=pramagent
POSTGRES_DB=pramagent
API_PORT=8080
DASHBOARD_PORT=8501
